# ────────────────────────────────────────────────────────────
# Fuxi (伏羲) — Environment Variables
# ────────────────────────────────────────────────────────────
# 复制此文件为 .env 并填入实际值
#   cp .env.example .env
# ────────────────────────────────────────────────────────────

# === 数据根目录（必填）========================================
# 指向包含所有 GEO 数据集文件夹的目录，例如:
#   WSL:     export FUXI_DATA_ROOT=/mnt/e/neurobiology
#   Windows: set FUXI_DATA_ROOT=E:/neurobiology
#   Mac:     export FUXI_DATA_ROOT=/Volumes/data/neurobiology
FUXI_DATA_ROOT=

# 兼容旧名（FUXI_DATA_ROOT 优先）:
# SCRNA_DATA_ROOT=

# === LLM API =================================================
LLM_API_KEY=sk-your-key-here
# LLM_API_BASE=http://localhost:8000/v1

# === HDF5 文件锁定 (WSL 用户) =================================
# WSL /mnt 挂载不支持 fcntl 文件锁，需关闭 h5py 锁定
# export HDF5_USE_FILE_LOCKING=FALSE
